# MotherDuck (https://motherduck.com) — required for warehouse sync
motherduck_token=
MOTHERDUCK_DATABASE=flairbnb

# Use local DuckDB file instead of MotherDuck (for offline/dev)
# FLAIRBNB_DB_PATH=./data/flairbnb.duckdb

# Scrape defaults
FLAIRBNB_CURRENCY=INR
FLAIRBNB_LANGUAGE=en
FLAIRBNB_PROXY_URL=
SCRAPE_DELAY_MS=200
SYNC_MAX_LISTINGS_PER_MARKET=50
SYNC_CALENDAR_REFRESH_LIMIT=20
SYNC_CALENDAR_MONTHS=1
SYNC_DETAILS_REFRESH_LIMIT=20
SYNC_ENRICH_WORKERS=5
SYNC_SEARCH_NIGHTS=3
SYNC_ZOOM=12
